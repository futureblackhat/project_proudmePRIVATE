# ProudMe backend, environment variable template.
#
# Copy this file to `.env` (which is git-ignored) and fill in the real values.
# The `.env` file is loaded by `dotenv` at process start (see server.js line 1).
#
# DO NOT commit `.env`. DO NOT paste real values into this file.

# MongoDB Atlas connection string. Format:
#   mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority
# Variable name is REACT_APP_MONGODB_URI for historical reasons (it predates the
# React-frontend → Flutter migration). Renaming would require a Render env-var
# update; not worth the churn.
REACT_APP_MONGODB_URI=

# SendGrid API key with "Mail Send" scope ONLY. Restricted-Access keys are
# preferred over Full-Access keys per least-privilege.
SENDGRID_API_KEY=

# OpenAI API key for the chatbot feedback feature.
OPEN_AI_API_KEY=

# JWT signing secret. Use a high-entropy random value (e.g. `openssl rand -hex 64`).
# If this leaks, every issued token is forgeable, rotate immediately.
JWT_SECRET=

# Optional. Defaults to 3001 for local dev. Render injects its own PORT
# value at runtime; do not hard-code.
# PORT=3001
